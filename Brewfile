# Brewfile — Homebrew dependencies assumed by these dotfiles.
# Install with:  brew bundle --file=Brewfile   (install.sh does this for you)
#
# Add a line per tool the configs depend on, then re-run install.sh.

# git pager configured in gitconfig (core.pager = delta)
brew "git-delta"

# nvm sourcing configured in zshrc
brew "nvm"

# standalone CLI tool, no dotfiles config
brew "bat"
