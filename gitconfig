[user]
	name = Paul.McConnell
	email = paul.mcconnell@wwt.com
[core]
  autocrlf = input
  editor = vim
  pager = delta
[color]
  ui = true
[color "diff"]
  meta = yellow bold
[diff]
  compactionHeuristic = true
[push]
  default = simple
	autoSetupRemote = true
[alias]
  configs = config --list --show-origin
  ap = add -p
  f = fetch
  s = status -s
  co = checkout
  cop = checkout -p
  st = status -sb
  cf = commit --fixup
  ci = commit
  c = commit
  ca = commit --amend
  cm = commit -m
  cp = cherry-pick
  cpc = cherry-pick --continue
  cia = commit --amend --no-edit
  dc = diff --cached
  p = push -u origin HEAD
  pf = push --force-with-lease
  br = branch
  rc = rebase --continue
  rhu = !git fetch && git reset --hard @{u}
  remaster = !git fetch && git rebase origin/master
  rebai = !git fetch && git rebase -i origin/master 
  ro = !sh -c 'git rebase --onto $1 $2 $(git rev-parse --abbrev-ref HEAD)' -
  lg = log --oneline --graph --format=\"%C(yellow)%h %C(auto)%d %C(dim white)%s\"
  lg2 = !sh -c 'git log --oneline --format=\"%C(yellow)%h %C(auto)%d %C(dim white)%<($1,trunc)%s\"' - $((`tput cols`-10))
  watch = !watch -c git lg --color
  showst = stash show -p
[pull]
  rebase = true
[branch]
  autosetuprebase = always
[rebase]
  autosquash = true
  autostash = true
# delta colorizes interactive hunk selection too (git add -p / checkout -p).
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true                    # n / N jump between files in the pager
  line-numbers = true
  tabs = 2                           # preserve the old `less --tabs=2` width
  syntax-theme = Nord                # muted, low-contrast dark theme
  # keep decorations quiet (no box-drawing around files/hunks)
  file-style = "#8fbcbb"
  file-decoration-style = ul
  hunk-header-decoration-style = none
[merge]
  conflictstyle = diff3
[stash]
  showPatch = true

